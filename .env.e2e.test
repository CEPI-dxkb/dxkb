# Playwright e2e environment — committed, loaded by playwright.config.ts webServer.
#
# Every outbound URL points at the loopback /api/e2e-mock/... catch-all so that
# server components / route handlers never attempt a real backend fetch while
# the browser suite runs. page.route() only sees browser requests, so without
# this the server prints "JSON-RPC call failed: HTTP error! status: 500" noise
# on every request.
#
# Override locally with .env.e2e.local (gitignored, loaded first so it wins).
# Never use these values outside the e2e harness.
#
# `${E2E_PORT}` is substituted by e2e/scripts/start-webserver.mjs at load time
# using the resolved port (CLI arg > env > 3020). It is the only supported
# template token here.

E2E_MOCK_ENABLED=1

# JSON-RPC service
APP_SERVICE_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/app-service

# Workspace + data APIs
WORKSPACE_API_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/workspace
NEXT_PUBLIC_DATA_API=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/data
DATA_SERVICE_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/data-service
SERVICES_API_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/services
SRA_VALIDATION_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/sra-validation
MINHASH_SERVICE_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/minhash

# BV-BRC user service (auth / profile / verification)
USER_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/user
USER_AUTH_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/user-auth
USER_REGISTER_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/user-register
USER_PASSWORD_RESET_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/user-password-reset
USER_VERIFICATION_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/user-verification
BVBRC_WEBSITE_API_URL=http://127.0.0.1:${E2E_PORT}/api/e2e-mock/bvbrc-website

# Upload origin allowlist — loopback only, no real shock node reachable.
SHOCK_ORIGINS=http://127.0.0.1:${E2E_PORT}

# Quick-reference link rendered by /workspace/[username]/** server components.
# Never fetched, only used as an href.
WORKSPACE_GUIDE_URL=https://www.bv-brc.org/docs/quick_references/workspace_groups_upload.html
